{
  "name": "@asi/identity",
  "version": "0.1.0-pre",
  "description": "ASI/I — Archetypes Solution Intel identity service. First adoption of the solution-intel archetype's identity slice (wraps the simple-auth/bangauth pattern; 5-role grant ledger).",
  "author": "William Fredricks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wfredricks/archetypes-solution-intelligence.git",
    "directory": "identity"
  },
  "homepage": "https://github.com/wfredricks/archetypes-solution-intelligence#readme",
  "bugs": {
    "url": "https://github.com/wfredricks/archetypes-solution-intelligence/issues"
  },
  "keywords": [
    "archetypes-solution-intelligence",
    "asi",
    "identity",
    "authentication",
    "authorization",
    "solution-intel-adoption",
    "typescript"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "bin": {
    "asi-identity": "dist/server.js"
  },
  "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
